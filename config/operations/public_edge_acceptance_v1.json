{
  "schema": "w2.public_edge_acceptance.v1",
  "minimum_independent_public_observers": 2,
  "target_route": {
    "status": "UNDECLARED",
    "observer_id": null,
    "production_review_requires_declaration": true
  },
  "thresholds": {
    "warm_keepalive_p95_seconds": 1.5,
    "next_page_p95_seconds": 3.0,
    "cold_p50_seconds": 4.0,
    "cold_p95_seconds": 8.0,
    "cold_max_seconds_exclusive": 12.0,
    "max_502_504_timeout_count": 0
  },
  "observer_kinds": {
    "SERVER_DIAGNOSTIC": [
      "API_CONTAINER_DIRECT",
      "STAGING_HOST_ISOLATED_NGINX"
    ],
    "PUBLIC_BLOCKING": [
      "GITHUB_HOSTED",
      "CURRENT_EXTERNAL_HOST",
      "AUTHORIZED_EXTERNAL_HOST"
    ]
  },
  "classifications": [
    "ALL_BLOCKING_OBSERVERS_PASS",
    "GLOBAL_PUBLIC_EDGE_BLOCKED",
    "TARGET_ROUTE_BLOCKED",
    "ROUTE_SPECIFIC_WARNING",
    "OBSERVER_COVERAGE_INSUFFICIENT"
  ],
  "failure_layers": [
    "DNS",
    "TCP_CONNECT",
    "TLS_HANDSHAKE",
    "OUTER_EDGE_OR_PROXY",
    "STAGING_NGINX",
    "NGINX_TO_API",
    "API_BUILD",
    "RESPONSE_TRANSFER"
  ],
  "aggregation_policy": {
    "mix_observers": false,
    "mix_ip_protocols": false,
    "mix_connection_modes": false,
    "mix_proxy_and_direct": false,
    "drop_failed_samples": false
  }
}
