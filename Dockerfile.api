FROM python:3.12-slim
ARG W2_GIT_SHA=UNKNOWN
ARG W2_BUILD_TIME=UNKNOWN
ARG W2_RELEASE_ID=${W2_GIT_SHA}
ARG PIP_INDEX_URL=
ARG UV_INDEX_URL=
ENV VIRTUAL_ENV=/app/.venv
ENV PATH=/app/.venv/bin:$PATH \
    W2_GIT_SHA=${W2_GIT_SHA} \
    W2_BUILD_TIME=${W2_BUILD_TIME} \
    W2_RELEASE_ID=${W2_RELEASE_ID} \
    PIP_INDEX_URL=${PIP_INDEX_URL} \
    UV_INDEX_URL=${UV_INDEX_URL}
WORKDIR /app
RUN useradd --create-home --uid 10001 w2
COPY pyproject.toml uv.lock README.md ./
COPY apps ./apps
COPY src ./src
COPY config ./config
COPY config/policies/lineup_market_policy.v1.json /app/image_config/policies/lineup_market_policy.v1.json
COPY migrations ./migrations
COPY scripts/run_w2_market_timeline_refresh.py \
     scripts/check_w2_market_timeline.py \
     scripts/run_w2_handicap_walkforward.py \
     scripts/clean_w2_legacy_ah_pool.py \
     scripts/run_w2_formal_tracking.py \
     scripts/check_w2_formal_tracking.py \
     scripts/run_w2_forward_outcome_ledger.py \
     scripts/run_w2_independent_signal_backfill.py \
     scripts/run_w2_report_runner.py \
     scripts/publish_w2_static_report.py \
     scripts/run_w2_settlement_history.py \
     scripts/check_w2_production_readiness.py \
     scripts/export_w2_audit_tables.py \
     scripts/debug_w2_modeling_sanity.py \
     scripts/debug_w2_s2_calibration_validation.py \
     scripts/lmm_transfermarkt_snapshot.py \
     scripts/lmm_materialize_stored_lineups.py \
     scripts/materialize_analysis_card_canary.py \
     ./scripts/
RUN pip install --no-cache-dir uv && uv sync --no-dev --frozen --no-editable && chown -R w2:w2 /app/.venv
RUN test -x /app/.venv/bin/w2-gate5-preflight
RUN test -f /app/scripts/run_w2_market_timeline_refresh.py \
 && test -f /app/scripts/check_w2_market_timeline.py \
 && test -f /app/scripts/run_w2_handicap_walkforward.py \
 && test -f /app/scripts/clean_w2_legacy_ah_pool.py \
 && test -f /app/scripts/run_w2_formal_tracking.py \
 && test -f /app/scripts/check_w2_formal_tracking.py \
 && test -f /app/scripts/run_w2_forward_outcome_ledger.py \
 && test -f /app/scripts/run_w2_independent_signal_backfill.py \
 && test -f /app/scripts/run_w2_report_runner.py \
 && test -f /app/scripts/publish_w2_static_report.py \
 && test -f /app/scripts/run_w2_settlement_history.py \
 && test -f /app/scripts/check_w2_production_readiness.py \
 && test -f /app/scripts/export_w2_audit_tables.py \
 && test -f /app/scripts/debug_w2_modeling_sanity.py \
 && test -f /app/scripts/debug_w2_s2_calibration_validation.py \
 && test -f /app/scripts/lmm_transfermarkt_snapshot.py \
 && test -f /app/scripts/lmm_materialize_stored_lineups.py \
 && test -f /app/scripts/materialize_analysis_card_canary.py \
 && W2_LINEUP_POLICY_PATH=/app/image_config/policies/lineup_market_policy.v1.json \
    /app/.venv/bin/python -c "from w2.lineups.intelligence import lineup_market_policy; assert lineup_market_policy()['schema_version'] == 'w2.lineup_market_policy.v1'"
LABEL org.opencontainers.image.source="w2-football-intelligence-engine" \
      org.opencontainers.image.revision="${W2_GIT_SHA}" \
      org.opencontainers.image.created="${W2_BUILD_TIME}" \
      w2.release.id="${W2_RELEASE_ID}" \
      w2.runtime.contract.version="release-train-2-patch2"
USER w2
HEALTHCHECK CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/ready', timeout=2)"
CMD ["uvicorn", "apps.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
