{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "W2 Registered Roster Snapshot V1",
  "type": "object",
  "required": [
    "roster_snapshot_id",
    "transfermarkt_club_id",
    "transfermarkt_player_id",
    "snapshot_date",
    "snapshot_status",
    "source_sha256"
  ],
  "properties": {
    "roster_snapshot_id": { "type": "string", "minLength": 1 },
    "transfermarkt_club_id": { "type": "string", "minLength": 1 },
    "transfermarkt_player_id": { "type": "string", "minLength": 1 },
    "snapshot_date": { "type": "string", "format": "date-time" },
    "snapshot_status": { "enum": ["COMPLETE", "INCOMPLETE"] },
    "source_sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
  },
  "additionalProperties": true
}
