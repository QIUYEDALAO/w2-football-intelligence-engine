{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "W2 Team Crosswalk V1",
  "type": "object",
  "required": [
    "api_football_team_id",
    "transfermarkt_club_id",
    "competition_id",
    "valid_from",
    "source_refs",
    "source_sha256",
    "evidence",
    "reviewed_by",
    "reviewed_at",
    "review_status"
  ],
  "properties": {
    "api_football_team_id": { "type": "string", "minLength": 1 },
    "transfermarkt_club_id": { "type": "string", "minLength": 1 },
    "competition_id": { "type": "string", "minLength": 1 },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_to": { "type": ["string", "null"], "format": "date-time" },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "source_sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "evidence": { "type": "object", "minProperties": 1 },
    "reviewed_by": { "type": "string", "minLength": 1 },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "review_status": { "enum": ["APPROVED", "REVIEW_REQUIRED", "CONFLICT"] }
  },
  "additionalProperties": true
}
