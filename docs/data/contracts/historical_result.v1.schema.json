{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "W2 Historical Result V1",
  "type": "object",
  "required": [
    "provider_fixture_id",
    "result_status",
    "final_home_goals_90",
    "final_away_goals_90",
    "result_source_sha256"
  ],
  "properties": {
    "provider_fixture_id": { "type": "string", "minLength": 1 },
    "result_status": { "enum": ["FINAL", "FT"] },
    "final_home_goals_90": { "type": ["integer", "string"] },
    "final_away_goals_90": { "type": ["integer", "string"] },
    "result_source_sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "result_reference_id": { "type": "string" },
    "result_row_hash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
  },
  "additionalProperties": true
}
