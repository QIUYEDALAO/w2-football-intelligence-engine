ARG UV_BOOTSTRAP_IMAGE=ghcr.io/astral-sh/uv:0.11.30
FROM ${UV_BOOTSTRAP_IMAGE} AS uv-bootstrap
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app
COPY --from=uv-bootstrap /uv /usr/local/bin/uv
COPY pyproject.toml uv.lock* README.md ./
COPY src ./src
RUN uv --version && (uv sync --frozen --all-groups || uv sync --all-groups)
COPY . .
ENV PATH="/app/.venv/bin:${PATH}"
