FROM node:20-slim AS build
WORKDIR /app
COPY apps/web/package.json apps/web/package-lock.json ./
RUN npm ci --ignore-scripts --no-audit --no-fund
ARG VITE_GIT_SHA=UNKNOWN
ARG VITE_BUILD_TIME=UNKNOWN
ARG W2_RELEASE_ID=${VITE_GIT_SHA}
ARG VITE_DASHBOARD_DATA_MODE=api
ARG VITE_W2_MARKET_ANCHOR_DISPLAY_ENABLED=false
ARG VITE_W2_MARKET_ANCHOR_MIN_DIVERGENCE=0.05
ENV VITE_GIT_SHA=${VITE_GIT_SHA} \
    VITE_BUILD_TIME=${VITE_BUILD_TIME} \
    W2_RELEASE_ID=${W2_RELEASE_ID} \
    VITE_DASHBOARD_DATA_MODE=${VITE_DASHBOARD_DATA_MODE} \
    VITE_W2_MARKET_ANCHOR_DISPLAY_ENABLED=${VITE_W2_MARKET_ANCHOR_DISPLAY_ENABLED} \
    VITE_W2_MARKET_ANCHOR_MIN_DIVERGENCE=${VITE_W2_MARKET_ANCHOR_MIN_DIVERGENCE}
COPY apps/web ./
RUN npm run build
FROM nginxinc/nginx-unprivileged:1.27-alpine
ARG VITE_GIT_SHA=UNKNOWN
ARG VITE_BUILD_TIME=UNKNOWN
ARG W2_RELEASE_ID=${VITE_GIT_SHA}
LABEL org.opencontainers.image.source="w2-football-intelligence-engine" \
      org.opencontainers.image.revision="${VITE_GIT_SHA}" \
      org.opencontainers.image.created="${VITE_BUILD_TIME}" \
      w2.release.id="${W2_RELEASE_ID}"
COPY --from=build /app/dist /usr/share/nginx/html
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf
USER 101
HEALTHCHECK CMD wget -qO- http://127.0.0.1:8080/ || exit 1
