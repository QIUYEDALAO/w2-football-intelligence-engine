FROM python:3.12-slim
WORKDIR /app
RUN useradd --create-home --uid 10001 w2
COPY pyproject.toml uv.lock README.md ./
COPY apps ./apps
COPY src ./src
RUN pip install --no-cache-dir uv && uv sync --no-dev --frozen
USER w2
HEALTHCHECK CMD uv run python -c "from apps.scheduler.main import heartbeat; assert 'heartbeat' in heartbeat()"
CMD ["uv", "run", "python", "-m", "apps.scheduler.main"]
